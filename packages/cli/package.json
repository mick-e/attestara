{
  "name": "@attestara/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "attestara": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@attestara/sdk": "workspace:*",
    "@attestara/types": "workspace:*",
    "chalk": "^5.3.0",
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
