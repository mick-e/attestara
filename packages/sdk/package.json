{
  "name": "@attestara/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./credentials": {
      "types": "./dist/credentials/index.d.ts",
      "import": "./dist/credentials/index.js"
    },
    "./prover": {
      "types": "./dist/prover/index.d.ts",
      "import": "./dist/prover/index.js"
    },
    "./negotiation": {
      "types": "./dist/negotiation/index.d.ts",
      "import": "./dist/negotiation/index.js"
    },
    "./commitment": {
      "types": "./dist/commitment/index.d.ts",
      "import": "./dist/commitment/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@attestara/types": "workspace:*",
    "@veramo/core": "^6.0.0",
    "@veramo/did-manager": "^6.0.0",
    "@veramo/did-provider-ethr": "^6.0.0",
    "@veramo/did-resolver": "^6.0.0",
    "@veramo/key-manager": "^6.0.0",
    "@veramo/kms-local": "^6.0.0",
    "did-resolver": "^4.1.0",
    "ethr-did-resolver": "^11.0.0",
    "ethers": "^6.13.0",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
